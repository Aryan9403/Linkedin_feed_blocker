{
  "manifest_version": 3,
  "name": "LinkedIn Feed Blocker",
  "version": "1.0",
  "description": "Blocks the LinkedIn feed to reduce distraction",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LinkedIn Feed Blocker"
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["content.js"]
    }
  ]
}